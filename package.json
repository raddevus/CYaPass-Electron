{
  "name": "CYaPass",
  "version": "1.5.0",
  "description": "Never type a password again. And, never memorize or make up a password again.",
  "main": "js/main.js",
  "scripts": {
    "start": "electron-forge start",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "dist": "electron-builder"
  },
  "repository": "https://github.com/raddevus/CYaPass-Electron",
  "keywords": [
    "C'YaPass",
    "CYaPass",
    "password",
    "never",
    "type",
    "again"
  ],
  "author": "Roger Deutsch <admin@cyapass.com> (https://cyapass.com/)",
  "license": "CC0-4.0",
  "devDependencies": {
    "@electron-forge/cli": "^6.4.1",
    "@electron-forge/maker-deb": "^6.4.1",
    "@electron-forge/maker-rpm": "^6.4.1",
    "@electron-forge/maker-snap": "^6.4.1",
    "@electron-forge/maker-squirrel": "^6.4.1",
    "@electron-forge/maker-zip": "^6.4.1",
    "@electron-forge/plugin-auto-unpack-natives": "^6.4.1",
    "electron": "^37.2.0",
    "electron-builder": "^26.0.12",
    "electron-toolkit": "^1.0.2"
  },
  "dependencies": {
    "@electron-forge/maker-dmg": "^6.4.1",
    "@electron-forge/maker-snap": "^6.4.1",
    "bootstrap": "^4.5.2",
    "dot-prop": ">=4.2.1",
    "electron-squirrel-startup": "^1.0.0",
    "jquery": "^3.5.1",
    "lodash": "^4.17.21",
    "minimist": "^1.2.8",
    "phin": "^3.7.1",
    "request": "^2.88.2",
    "tough-cookie": "^4.1.3"
  },
  "build": {
    "appId": "com.cyapass.CYaPass",
    "copyright": "Copyright © 2022 roger deutsch",
    "productName": "CYaPass",
    "electronVersion": "37.2.0",
    "asar": true,
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "linux": {
      "category": "Utility.Passwords",
      "executableName": "cyapass",
      "target": [
        "AppImage",
        "deb",
        "rpm"
      ]
    },
    "win": {
      "icon": "build/CYaPass512x512.png"
    },
    "mac": {
      "target": "dmg",
      "category": "public.app-category.utilities"
    },
    "dmg": {
      "title": "${productName} ${version}",
      "background": "build/CYaPass.png",
      "icon": "build/icon.icns",
      "contents": [
        {
          "x": 130,
          "y": 220,
          "type": "file"
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ],
      "window": {
        "width": 540,
        "height": 380
      }
    }
  }
}
